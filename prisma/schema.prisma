generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique
  name          String
  email         String         @unique
  image         String
  createdAt     DateTime       @default(now())
  departmentId  String?
  approved      Boolean        @default(false)
  announcements Announcement[]
  department    Department?    @relation(fields: [departmentId], references: [id])
}

model Announcement {
  id        String           @id @default(cuid())
  creatorId String
  type      AnnouncementType
  title     String
  content   String?
  createdAt DateTime         @default(now())
  creator   User             @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}

model Department {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String    @unique
  image       String
  description String
  contact     String
  images      Gallery[]
  schemes     Scheme[]
  moderators  User[]
}

model Gallery {
  id           String      @id @default(cuid())
  url          String
  type         GalleryType
  departmentId String?
  schemeId     String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  scheme       Scheme?     @relation(fields: [schemeId], references: [id], onDelete: Cascade)
}

model Scheme {
  id                  String     @id @default(cuid())
  slug                String     @unique
  name                String
  shortDesc           String
  description         String
  image               String?
  departmentId        String
  creatorId           String
  type                SchemeType
  eligibility         String?
  deadline            DateTime?
  benifits            String?
  howToApply          String?
  documentsReq        String?
  applyLink           String?
  applicationFormLink String?
  createdAt           DateTime   @default(now())
  images              Gallery[]
  department          Department @relation(fields: [departmentId], references: [id])

  @@index([slug])
}

enum AnnouncementType {
  Alert
  Notice
  Update
}

enum GalleryType {
  Department
  Scheme
}

enum SchemeType {
  Central
  State
  Local
}
